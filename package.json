{
	"name": "youtube-live",
	"version": "3.1.0-dev",
	"type": "module",
	"main": "dist/index.js",
	"license": "MIT",
	"scripts": {
		"postinstall": "husky",
		"dev": "yarn build:watch",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"build": "rimraf dist && yarn build:main",
		"build:main": "tsc -p tsconfig.build.json",
		"build:watch": "tsc -p tsconfig.build.json --watch",
		"lint:raw": "eslint",
		"lint": "yarn lint:raw .",
		"knip": "knip",
		"test": "vitest --run"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bitfocus/companion-module-youtube-live.git"
	},
	"lint-staged": {
		"*.{js,json,md}": [
			"prettier --write"
		],
		"*.{js,mjs,ts}": [
			"yarn lint --fix"
		]
	},
	"engines": {
		"node": "^22.11"
	},
	"dependencies": {
		"@companion-module/base": "~1.13.0",
		"@googleapis/youtube": "^31.0.0",
		"google-auth-library": "^10.5.0"
	},
	"devDependencies": {
		"@companion-module/tools": "^2.6.1",
		"@types/node": "^22.15.18",
		"@vitest/eslint-plugin": "~1.6.13",
		"eslint": "~10.0.0",
		"husky": "^9.1.7",
		"knip": "^5.83.1",
		"lint-staged": "^13.2.0",
		"prettier": "^3.8.1",
		"rimraf": "^4.4.1",
		"type-testing": "^0.2.0",
		"typescript": "~6.0.3",
		"typescript-eslint": "~8.59.0",
		"vitest": "^4.1.5"
	},
	"packageManager": "yarn@4.14.1"
}
